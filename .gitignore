# The repo root IS the live ~/.hermes runtime dir, so ignore everything by
# default and explicitly allow only the backup artifacts we want versioned.
# This keeps the agent install, webui, node, logs, databases, sessions,
# secrets, and model blobs out of git automatically.

# Ignore all
*

# Allow the backup tree and docs
!.gitignore
!README.md
!LICENSE
!hermes-config/
!hermes-config/**

# Within the backup tree, still block anything secret-shaped
hermes-config/**/.env
hermes-config/**/*.key
hermes-config/**/*.pem
hermes-config/**/*-credentials.json
hermes-config/**/*-sa.json
hermes-config/**/hermes.env
hermes-config/**/webui.ctl.env
hermes-config/models/blobs/
hermes-config/models/*.gguf
hermes-config/models/*.bin
