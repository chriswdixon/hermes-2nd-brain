# Security: Never commit actual secrets
.env
.env.local
.env.*.local
*.key
*.pem
*-credentials.json
*-sa.json
secrets/
.secrets
private/

# Local development
node_modules/
.DS_Store
*.swp
*.swo
*~

# API Keys and tokens (even if named differently)
*api*key*
*access*token*
*secret*
*password*
*auth*
*.token

